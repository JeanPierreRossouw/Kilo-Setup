{
  "name": "kilo/project",
  "type": "project",
  "require": {},
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "prune": [
      "vendor/bin/rector process",
      "vendor/bin/pint",
      "npm run lint:fix"
    ],
    "validate": [
      "vendor/bin/rector process --dry-run",
      "vendor/bin/phpstan analyse --memory-limit=2G",
      "@php artisan test --parallel --coverage --min=85",
      "npm run type-check",
      "npm run build"
    ]
  }
}
