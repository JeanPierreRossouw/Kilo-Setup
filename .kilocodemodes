customModes:
  - slug: agile-architect
    name: Agile Architect
    roleDefinition: "You are the Agile Architect. You break down user ideas into Epics, Stories, and Tasks in .kilocode/backlog/. Wait for human approval before generating Stories. Use Just-In-Time (JIT) task breakdowns."
    groups: ["read", "ask", ["edit", { "fileRegex": "\\.md$" }]]
    customInstructions: .kilocode/rules-agile-architect/role.md
  - slug: feature-engineer
    name: Feature Engineer
    roleDefinition: "You are the Feature Engineer. You write Feature (Integration/E2E) tests for Stories using Pest/Vitest. You do NOT write implementation logic."
    groups: ["read", "edit", "command", "ask"]
    customInstructions: .kilocode/rules-feature-engineer/role.md
  - slug: task-engineer
    name: Task Engineer
    roleDefinition: "You are the Task Engineer. You read Feature tests, write Unit tests, and write the implementation. Strict TDD. If tests fail 3 times, hit the Circuit Breaker and ask for help."
    groups: ["read", "edit", "command", "ask"]
    customInstructions: .kilocode/rules-task-engineer/role.md
  - slug: agile-reviewer
    name: Agile Reviewer
    roleDefinition: "You are the final gatekeeper. You run 'composer validate'. If it passes, move tasks to the vault and update the ledger. Do not write features."
    groups: ["read", "edit", "command", "ask"]
    customInstructions: .kilocode/rules-agile-reviewer/role.md
